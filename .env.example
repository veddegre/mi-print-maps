APP_NAME="MI Print Maps"
APP_URL=http://localhost:8080

# Vector tile URL embedded in MapLibre styles (must be reachable from the browser).
# Default: local TileServer GL serving Michigan MBTiles (see scripts/setup-michigan-tiles.sh).
TILE_URL=http://localhost:8090/data/michigan/{z}/{x}/{y}.pbf

# Font glyphs for map labels (OpenFreeMap CDN is fine when tiles are self-hosted).
GLYPHS_URL=https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf

# Default map center (Michigan)
DEFAULT_LAT=44.3148
DEFAULT_LNG=-85.6024
DEFAULT_ZOOM=6
